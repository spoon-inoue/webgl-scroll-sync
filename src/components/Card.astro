---
interface Props {
  data: {
    path: string
    aspect: number
    title: string
  }
}

const { data } = Astro.props
---

<li class="card">
  <div class="thumbnail" style={`aspect-ratio: ${data.aspect};`} data-path={import.meta.env.BASE_URL + data.path}></div>
  <p class="title">{data.title}</p>
</li>

<style lang="scss" is:global>
  @use '/src/styles/mixins/media.scss' as *;

  .card {
    width: fit-content;
    .thumbnail {
      width: 70rem;
      border: 1px solid;
      @include sp {
        width: 90rem;
      }
    }
    .title {
      width: fit-content;
      margin-top: 1rem;
      margin-left: auto;
      font-size: 15px;
      @include sp {
        font-size: 12px;
      }
    }
  }
</style>
